_app_util_update_script() {
  local update
  if [ -z "$CLI_PATH" ]; then
    ui_notify_critical "Can't find $CLI_NAME in PATH"
  fi

  if [ ! -w "$CLI_PATH" ]; then
    ui_confirm "It seems you have installed $CLI_NAME as root, which is not recommended. Do you still want to update using sudo? (I recommended reinstalling the cli as non root)" || _util_byebye
    if _dep_ch sudo; then
      exec sudo -s "$CLI_PATH" "-u"
    else
      ui_notify_critical "Insufficient permissions to update and can't find sudo in PATH"
    fi
  fi

  update=$(curl -s "$CLI_URL")
  [ -z "$update" ] && ui_notify_critical "Failed to fetch update information"
  update="$(printf "%s\n" "$update" | diff -u "$CLI_PATH" - 2>/dev/null)"
  if [ -z "$update" ]; then
    ui_notify "Script is up to date :)"
  else
    if printf "%s" "$update" | patch "$CLI_PATH" -; then
      ui_notify "Script has been updated!"
    else
      ui_notify_critical "Can't update for some reason!"
    fi
  fi
  exec "$CLI_PATH"
}

_app_util_check_update() {
  local update
  update=$(curl -s "$CLI_URL")
  [ -z "$update" ] && ui_notify_critical "Failed to fetch update information"
  update="$(printf "%s\n" "$update" | diff -u "$CLI_PATH" -)"
  if [ -n "$update" ]; then
    # TODO: show pretty diffs
    ui_confirm "An update has been found would you like to see the changes before deciding whether to update?" && echo "$update" | ui_pager
    ui_confirm "Would you like to proceed with the update?" && _app_util_update_script
  else
    return 1
  fi
}

