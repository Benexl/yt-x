}

# ==============================================================================
# APP:cmdline parser
# ==============================================================================
__app_cmd_line_parser_completions() {
  [ -n "$2" ] || _app_usage 1
  case "$2" in
  -f | --fish) _app_completions_fish ;;
  -b | --bash)
    # TODO: write bash completions
    echo Contribute to "$CLI_NAME" by writing bash completions
    exit 1
    ;;
  -z | --zsh)
    # TODO: write zsh completions
    echo Contribute to "$CLI_NAME" by writing zsh completions
    exit 1
    ;;
  -h | --help) _app_usage_completions ;;
  *) _app_usage_completions 1 ;;
  esac

}

__app_cmd_line_parser_extensions() {
  [ -n "$2" ] || usage 1
  if [ "${2#/}" != "$2" ]; then
    . "$2"
  else
    . "$CLI_EXTENSION_DIR/$2"
  fi
  shift

}

_app_cmd_line_parser() {
  while [ $# -gt 0 ]; do
    case "$1" in
    -h | --help) _app_usage ;;
    -v | --version)
      echo "$CLI_NAME v$CLI_VERSION MIT Copyright © 2024 $CLI_AUTHOR projects"
      exit 0
      ;;
    -e | --edit-config)
      _app_edit_config
      ;;
    -U | --update)
      ! _app_util_check_update && ui_notify "No updates found, script is up to date :)" && _util_byebye
      ;;
    -S | --search)
      CMD_ACTION="Search"
      CMD_SEARCH_TERMS="$2"
      shift
      ;;
    -l | --launcher)
      [ -n "$2" ] || _app_usage 1
      CONFIG_LAUNCHER="$2"
      shift
      ;;
    -i | --preview)
      CONFIG_ENABLE_PREVIEW=true
      ;;
    -I | --no-preview)
      CONFIG_ENABLE_PREVIEW=false
      ;;
    --disown-streaming-process)
      CONFIG_DISOWN_STREAMING_PROCESS=true
      ;;
    --no-disown-streaming-process)
      CONFIG_DISOWN_STREAMING_PROCESS=false
      ;;
    --disown-downloading-process)
      CONFIG_DISOWN_DOWNLOADING_PROCESS=true
      ;;
    --no-disown-downloading-process)
      CONFIG_DISOWN_DOWNLOADING_PROCESS=false
      ;;
    --rofi-theme-main)
      [ -n "$2" ] || _app_usage 1
      CONFIG_ROFI_THEME_MAIN="$2"
      shift
      ;;
    --rofi-theme-preview)
      [ -n "$2" ] || _app_usage 1
      CONFIG_ROFI_THEME_PREVIEW="$2"
      shift
      ;;
    --rofi-theme-prompt)
      [ -n "$2" ] || _app_usage 1
      CONFIG_ROFI_THEME_PROMPT="$2"
      shift
      ;;
    --rofi-theme-confirm)
      [ -n "$2" ] || _app_usage 1
      CONFIG_ROFI_THEME_CONFIRM="$2"
      shift
      ;;
    -p | --player)
      [ -n "$2" ] || _app_usage 1
      CONFIG_PLAYER="$2"
      shift
      ;;
    -E | --generate-desktop-entry) _app_generate_desktop_entry ;;
    completions) __app_cmd_line_parser_completions "$@" ;;
    -x | --extensions) __app_cmd_line_parser_extensions "$@" ;;
    *) _app_usage 1 ;;
    esac
    shift
  done
}

# ==============================================================================
# App
# ==============================================================================
main() {
  trap _util_byebye INT TERM
  _init_env
  _load_config
  _app_cmd_line_parser "$@"
  _app_update_check
  _app_core_dep_ch
  menu_main
}

main "$@"

