_menu_playlist_explorer() {
  local search_results
  local titles
  local choices
  choices="\
    $TXT_MENU_NEXT
    $TXT_MENU_PREVIOUS
    $TXT_MENU_BACK
    $TXT_MENU_EXIT
    "
  while true; do
    search_results=$(echo "$search_results" | jq "
          .entries=(.entries 
          | to_entries
          | map(.value.title=\"\(.key+1|tostring| if (.|length) < 2 then \"0\" + . else . end) \"+.value.title) 
          |map(.value))
          ")
    titles=$(echo "$search_results" | jq '.entries[].title' -r 2>/dev/null)
    title="$(printf "%s\n%s" "$titles" "$choices" | launcher_with_preview "$TXT_MENU_PLAYLIST_EXPLORER_PROMPT" "playlist" | tr -d '\n' | sed 's/^[^0-9]  //g' | sed 's/"/\\"/g')"
    clear

    case "$title" in
    "$TXT_MENU_NEXT") __menu_playlist_explorer_next ;;
    "$TXT_MENU_PREVIOUS") __menu_playlist_explorer_previous ;;
    "$TXT_MENU_BACK" | "") break ;;
    "$TXT_MENU_EXIT") _util_byebye ;;
    esac
    _menu_playlist_actions
  done
