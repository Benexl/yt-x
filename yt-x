_dep_ch() {
  command -v "$1" >/dev/null 2>&1
}

__init_env_platform() {
  CLI_DIR="$(dirname "$(realpath "$0")")"
  CLI_PATH="$CLI_DIR/$CLI_NAME"

  # If we are in Zsh, enable word splitting for the duration of the script
  if [ -n "$ZSH_VERSION" ]; then
    setopt shwordsplit
  fi

  # check if supports local
  if ! _dep_ch local; then
    # shellcheck disable=SC02329
    __local() {
      unset "$1"
      eval "$1=''"
    }
    # shellcheck disable=SC02329
    local() {
      __local "$1"
    }
  fi

  case "$(uname -a)" in
  *ndroid*) CLI_PLATFORM="android" ;;
  *Darwin*) CLI_PLATFORM="mac" ;;
  *MINGW* | *WSL2*) CLI_PLATFORM="windows" ;;
  *) CLI_PLATFORM="linux" ;;
  esac

  # Detect if terminal
  if [ -t 1 ]; then
    CLI_IS_TERMINAL=true
  else
    CLI_IS_TERMINAL=false
  fi

  # Detect if terminal supports true color
  if [ "$COLORTERM" = "truecolor" ] || [ "$COLORTERM" = "24bit" ]; then
    CLI_SUPPORTS_TRUE_COLOR=true
  else
    CLI_SUPPORTS_TRUE_COLOR=false
  fi

  # Detect correct mpv command (mpv or mpv.exe)
  if _dep_ch mpv; then
    MPV_CMD="mpv"
  elif _dep_ch "mpv.exe"; then
    MPV_CMD="mpv.exe"
  else
    MPV_CMD="mpv" # fallback
  fi

}

__init_env_paths() {

  XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
  XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
  XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"

  # Directories
  CLI_CONFIG_DIR="$XDG_CONFIG_HOME/$CLI_APP_NAME"
  CLI_EXTENSIONS_DIR="$CLI_CONFIG_DIR/extensions"
  CLI_EXTENSIONS_SITES_DIR="$CLI_EXTENSIONS_DIR/sites"
  CLI_EXTENSIONS_THEMES_DIR="$CLI_EXTENSIONS_DIR/themes"
  CLI_EXTENSIONS_LANGS_DIR="$CLI_EXTENSIONS_DIR/langs"
  CLI_EXTENSIONS_CMDS_DIR="$CLI_EXTENSIONS_DIR/cmds"

  CLI_CACHE_DIR="$XDG_CACHE_HOME/$CLI_APP_NAME"
  CLI_STATE_DIR="$CLI_CACHE_DIR/state"
  CLI_PREVIEW_DIR="$CLI_CACHE_DIR/previews"
  CLI_PREVIEW_IMGS_DIR="$CLI_CACHE_DIR/previews/images"
  CLI_PREVIEW_TXT_DIR="$CLI_CACHE_DIR/previews/text"
  CLI_PLAYLIST_DIR="$CLI_CACHE_DIR/playlists"
  CLI_ARCHIVE_DIR="$CLI_CACHE_DIR/archives"
  CLI_LOG_DIR="$CLI_CACHE_DIR/logs"

  # Files
  CLI_CONFIG_FILE="$CLI_CONFIG_DIR/config.sh"
  CLI_DEFAULT_THEME_FILE="$CLI_EXTENSIONS_THEMES_DIR/default.theme"
  CLI_DEFAULT_LANG_FILE="$CLI_EXTENSIONS_LANGS_DIR/default.lang"
  CLI_RECENT_FILE="$CLI_CONFIG_DIR/recent.json"
  CLI_SAVED_FILE="$CLI_CONFIG_DIR/saved_videos.json"
  CLI_CUSTOM_PLAYLISTS_FILE="$CLI_CONFIG_DIR/custom_playlists.json"
  CLI_SUBSCRIPTIONS_FILE="$CLI_CONFIG_DIR/subscriptions.json"
  CLI_CUSTOM_CMDS_FILE="$CLI_CONFIG_DIR/custom_cmds.json"

  CLI_STATE_FILE="$CLI_STATE_DIR/$(date +%Y-%m-%d_%H-%M-%S).json"
  CLI_LOG_FILE="$CLI_CACHE_DIR/logs/${CLI_NAME}.log"
  CLI_SEARCH_HISTORY_FILE="$CLI_CACHE_DIR/search_history.txt"
  CLI_LOG_FILE="$CLI_LOG_DIR/${CLI_NAME}.log"

  # Ensure directories exist
  mkdir -p \
    "$CLI_EXTENSIONS_SITES_DIR" \
    "$CLI_EXTENSIONS_THEMES_DIR" \
    "$CLI_EXTENSIONS_LANGS_DIR" \
    "$CLI_EXTENSIONS_CMDS_DIR" \
    "$CLI_STATE_DIR" \
    "$CLI_PREVIEW_IMGS_DIR" \
    "$CLI_PREVIEW_TXT_DIR" \
    "$CLI_PLAYLIST_DIR" \
    "$CLI_ARCHIVE_DIR" \
    "$CLI_LOG_DIR"

}

__post_init_env() {
