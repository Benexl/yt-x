__state_clean_prev() {
  local current_state_dir
  current_state_dir="$CLI_CURRENT_STATE_DIR/$STATE_CURRENT"
  ! [ -d "$current_state_dir" ] && ui_notify_critical "$TXT_STATE_MALFORMED_CURRENT"
  rm -rf "$current_state_dir"
}

_state_init() {
  STATE_CURRENT=0

  STATE_CURRENT_CHANNEL_RESULTS=""
  STATE_CURRENT_CHANNEL_RESULTS_START=1
  STATE_CURRENT_CHANNEL_RESULTS_END="$CONFIG_PER_PAGE"
  STATE_CURRENT_CHANNEL_URL=""
  STATE_CURRENT_CHANNEL_TITLE=""

  STATE_CURRENT_PLAYLIST_START=1
  STATE_CURRENT_PLAYLIST_END="$CONFIG_PER_PAGE"
  STATE_CURRENT_PLAYLIST_RESULTS=""
  STATE_CURRENT_PLAYLIST_URL=""
  STATE_CURRENT_PLAYLIST_TITLE=""

  STATE_CURRENT_VIDEO=""
  STATE_CURRENT_VIDEO_URL=""
  STATE_CURRENT_VIDEO_TITLE=""
}

_state_push() {
  local current_state_dir

  STATE_CURRENT="$((STATE_CURRENT + 1))"
  current_state_dir="$CLI_CURRENT_STATE_DIR/$STATE_CURRENT"
  mkdir -p "$current_state_dir"

  echo "$STATE_CURRENT_CHANNEL_RESULTS" >"$current_state_dir/channel_results"
  echo "$STATE_CURRENT_CHANNEL_RESULTS_START" >"$current_state_dir/channel_results_start"
  echo "$STATE_CURRENT_CHANNEL_RESULTS_END" >"$current_state_dir/channel_results_end"
  echo "$STATE_CURRENT_CHANNEL_URL" >"$current_state_dir/channel_url"
  echo "$STATE_CURRENT_CHANNEL_TITLE" >"$current_state_dir/channel_title"

  echo "$STATE_CURRENT_PLAYLIST_START" >"$current_state_dir/playlist_start"
  echo "$STATE_CURRENT_PLAYLIST_END" >"$current_state_dir/playlist_end"
  echo "$STATE_CURRENT_PLAYLIST_RESULTS" >"$current_state_dir/playlist_results"
  echo "$STATE_CURRENT_PLAYLIST_URL" >"$current_state_dir/playlist_url"
  echo "$STATE_CURRENT_PLAYLIST_TITLE" >"$current_state_dir/playlist_title"

  echo "$STATE_CURRENT_VIDEO" >"$current_state_dir/video"
  echo "$STATE_CURRENT_VIDEO_URL" >"$current_state_dir/video_url"
  echo "$STATE_CURRENT_VIDEO_TITLE" >"$current_state_dir/video_title"
}

_state_pop() {
  local current_state_dir

  __state_clean_prev

  STATE_CURRENT="$((STATE_CURRENT - 1))"
