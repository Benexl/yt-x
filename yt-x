Exec=$CLI_PATH --launcher rofi
Categories=Entertainment"
  else
    entry="\
[Desktop Entry]
Name=$CLI_NAME
Type=Application
Version=$CLI_VERSION
Path=$HOME
Comment=Browse Youtube from the terminal plus other sites yt-dlp supports
Terminal=true
Exec=$CLI_PATH --launcher fzf
Categories=Entertainment"
  fi

  printf "%s\n" "$entry"
  exit 0
}

_app_update_check() {
  local timestamp_file
  local interval
  local last_check_time

  if [ "$CONFIG_CHECK_FOR_UPDATES" = "true" ]; then
    timestamp_file="$CLI_CACHE_DIR/.last_update_check"

    # Time interval in seconds (6 hours = 21600 seconds)
    interval=$((12 * 60 * 60))

    # Determine whether to run the update check
    last_check_time=$(cat "$timestamp_file" 2>/dev/null || echo 0)

    if [ "$((CLI_START_TIME - last_check_time))" -ge "$interval" ]; then
      _app_util_check_update
      echo "$CLI_START_TIME" >"$timestamp_file"
    fi
  fi
}

_app_core_dep_ch() {
  ! _dep_ch "yt-dlp" >/dev/null 2>&1 && ui_notify_critical "yt-dlp is not installed and is a core dep please install it to proceed"
  ! _dep_ch "jq" && ui_notify_critical "jq is not installed and is a core dep please install it to proceed"
  ! _dep_ch "fzf" && ui_notify_critical "fzf is not installed and is a core dep please install it to proceed"
}

# ==============================================================================
# APP: usage
# ==============================================================================
_app_usage() {
  local help_msg
  help_msg="\
A script written to browse youtube from the terminal

Usage: $CLI_NAME [arguments] [options] 

Commandline options override the config

Options:
  -S, --search [Search Terms]
    search for a video
  -e, --edit-config
    edit $CLI_NAME config file
  --rofi-theme <path>
    set the path to your rofi config file
  --disown-streaming-process
    disown the streaming process so you can contine streaming even if you close $CLI_NAME
  --no-disown-streaming-process
