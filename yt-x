# ==============================================================================
# Data Fetching
# ==============================================================================
__fetch_yt_dlp() {
  local url
  local playlist_start
  local playlist_end
  local custom_opts

  url="$1"
  playlist_start="$2"
  playlist_end="$3"
  shift
  shift
  shift
  custom_opts="$*"

  # shellcheck disable=SC2086
  ui_load yt-dlp "$url" \
    --dump-single-json \
    --flat-playlist \
    --playlist-start "$playlist_start" \
    --playlist-end "$playlist_end" \
    $custom_opts
}
__fetch_video_url() {
  local url
  url="$1"

  ui_load yt-dlp "$url" --quiet --no-warnings --get-url | head -n 1
}

__fetch_audio_url() {
  local url
  url="$1"

  ui_load yt-dlp "$url" --quiet --no-warnings --get-url | tail -n 1
}

_fetch_media() {
  local custom_opts
  local url

  [ -n "$CONFIG_BROWSER" ] && custom_opts="--cookies-from-browser $CONFIG_BROWSER"

  url="$1"
  shift

  # shellcheck disable=SC2086
  __fetch_yt_dlp "$url" "$@" --extractor-args youtubetab:approximate_date $custom_opts
}

_fetch_playlist() {
  local url
  url="$1"

  STATE_CURRENT_PLAYLIST_RESULTS="$(
    _fetch_media "$url" "$STATE_CURRENT_PLAYLIST_START" "$STATE_CURRENT_PLAYLIST_END" |
      jq "
          .entries=(.entries 
          | to_entries
          | map(.value.title=\"\(.key+1|tostring| if (.|length) < 2 then \"0\" + . else . end) \"+.value.title) 
          |map(.value))
          "
  )"

  STATE_CURRENT_PLAYLIST_URL="$(echo "$STATE_CURRENT_PLAYLIST_RESULTS" | jq '.original_url' -r)"
  STATE_CURRENT_PLAYLIST_TITLE="$(echo "$STATE_CURRENT_PLAYLIST_RESULTS" | jq '.title' -r)"
}

fetch_playlist() {
  local url
  local base_url

  base_url="https://youtube.com"
  url="$base_url/$1"

  # fetching playlist for the first time, initialize the indices
  STATE_CURRENT_PLAYLIST_START=1
  STATE_CURRENT_PLAYLIST_END="$CONFIG_PER_PAGE"

  _fetch_playlist "$url"
  _state_push
}

fetch_playlist_next() {
  STATE_CURRENT_PLAYLIST_START="$((STATE_CURRENT_PLAYLIST_END + 1))"
  STATE_CURRENT_PLAYLIST_END="$((STATE_CURRENT_PLAYLIST_END + CONFIG_PER_PAGE))"

  _fetch_playlist "$STATE_CURRENT_PLAYLIST_URL"
  _state_push
}

fetch_playlist_prev() {
  [ "$((STATE_CURRENT_PLAYLIST_START - 1))" -gt 1 ] && _state_pop
}

# ==============================================================================
# Data Caching
# ==============================================================================
__cached_mix_path() {
  local url
  local video_id
  local _mix_data
  local cached_mix_path

  url="$1"
  video_id=$(echo "$STATE_CURRENT_VIDEO" | jq '.id' -r | sed 's/RD//g')

  cached_mix_path="$CLI_AUTO_GEN_PLAYLISTS/$(_util_generate_hash "https://www.youtube.com/watch?v=${video_id}&list=RD$video_id").m3u8"

  if ! [ -s "$cached_mix_path" ]; then
    _mix_data="$(yt-dlp "https://www.youtube.com/watch?v=${video_id}&list=RD$video_id" --flat-playlist --dump-single-json 2>/dev/null)"

    # NOTE: it silently fails and will just return the original url
    # if it fails to fetch the mix data, which can happen for various reasons (e.g. network issues, yt-dlp issues, etc.)
    [ -z "$_mix_data" ] && echo "$url" && return

    # start creating the m3u8 mix
    echo '#EXTM3U' >>"$cached_mix_path"
    lines="$(echo "$_mix_data" | jq '.entries[].url' -r | wc -l)"
    for i in $(seq 1 "$lines"); do
      local _video
      local _title
      local _channel
      local _url

      _video=$(echo "$_mix_data" | jq ".entries[$((i - 1))]")
      _title=$(echo "$_video" | jq ".title" -r)
      _channel=$(echo "$_video" | jq '.channel' -r)
      _url=$(echo "$_video" | jq '.url' -r)
      echo "#EXTINF:-1,$_title" >>"$cached_mix_path"
      echo "$_url" >>"$cached_mix"

      # NOTE: the data below is not available in the mix data of yt
      # but other sites may have them so...

      # echo "#EXTALB:Album Name" >>"$cached_mix"
      # echo "#EXTGENRE:Genre" >>"$cached_mix"
      # echo "#EXTGRP:Group Name" >>"$cached_mix"

      # newline
      echo "" >>"$cached_mix"
    done
  fi

  echo "$cached_mix_path"
}

_cached_mix_path_or_url() {
  local url
  url="$1"

  if echo "$url" | grep -q "list=RD"; then
    echo "$(ui_load __cached_mix_url "$url")"
  else
    echo "$url"
  fi
}

# ==============================================================================
# Data Viewers
# ==============================================================================
__player_mpv() {
  local url
  local mode
  local opts
  local mpv_cmd

  mode="$2"
  opts="$CONFIG_MPV_ARGS"

  case "$CLI_PLATFORM" in
  android)
    case "$mode" in
    listen)
      url="$(__fetch_audio_url "$1")"
      ;;
    *)
      url="$(__fetch_video_url "$1")"
      ;;
    esac
    nohup am start --user 0 -a android.intent.action.VIEW -d "$url" -n is.xyz.mpv/.MPVActivity >/dev/null 2>&1 &
    ;;
  *)
    url="$1"
    case "$mode" in
    listen)
      opts="$opts --no-video"
      ;;
    esac

    if _dep_ch mpv; then
      mpv_cmd="mpv"
    elif _dep_ch "mpv.exe"; then
      mpv_cmd="mpv.exe"
    else
      ui_notify_critical "$TXT_PLAYER_NOT_FOUND"
    fi

    $mpv_cmd "$url" "$opts"
    ;;
  esac
}

__player_vlc() {
  local url
  local mode
  local opts
  local vlc_cmd

  mode="$2"
  opts="$CONFIG_MPV_ARGS"

  case "$CLI_PLATFORM" in
  android)
    case "$mode" in
    listen)
      url="$(__fetch_audio_url "$1")"
      ;;
    *)
      url="$(__fetch_video_url "$1")"
      ;;
    esac
    nohup am start --user 0 -a android.intent.action.VIEW -d "$url" -n org.videolan.vlc/org.videolan.vlc.gui.video.VideoPlayerActivity -e "title" "$title" >/dev/null 2>&1 &
    ;;
  *)
    url="$1"
    case "$mode" in
    listen)
      opts="$opts --no-video"
      ;;
    esac

    if _dep_ch vlc; then
      vlc_cmd="vlc"
    elif _dep_ch "vlc.exe"; then
      vlc_cmd="vlc.exe"
    else
      ui_notify_critical "$TXT_PLAYER_NOT_FOUND"
    fi

    $vlc_cmd "$url" "$opts"
    ;;
  esac
}

__player_tplay() {
  local url
  local opts
  local tplay_cmd

  opts="$CONFIG_TPLAY_ARGS"

  case "$CLI_PLATFORM" in
  android)
    case "$mode" in
    listen)
      url="$(__fetch_audio_url "$1")"
      ;;
    *)
      url="$(__fetch_video_url "$1")"
      ;;
    esac
    nohup am start --user 0 -a android.intent.action.VIEW -d "$url" -n is.xyz.mpv/.MPVActivity >/dev/null 2>&1 &
    ;;
  *)
    url="$1"

    if _dep_ch tplay; then
      tplay_cmd="tplay"
    else
      ui_notify_critical "$TXT_PLAYER_NOT_FOUND"
    fi

    $tplay_cmd "$url" "$opts"
    ;;
  esac
}

_play() {
  case "$CONFIG_PLAYER" in
  mpv) __player_mpv "$1" "$2" ;;
  vlc) __player_vlc "$1" "$2" ;;
  tplay) __player_tplay "$1" "$2" ;;
  *) ui_notify_critical "$TXT_PLAYER_NOT_FOUND" ;;
  esac
}

play() {
  _play "$@"
}

