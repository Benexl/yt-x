_update_recent() {
  local current_recent
  local id
  local video_entry

  current_recent='{"entries":[]}'
  [ -s "$CLI_RECENT_FILE" ] && current_recent=$(cat "$CLI_RECENT_FILE")

  id=$(echo "$STATE_CURRENT_VIDEO" | jq '.id' -r)
  video_entry="$(echo "$STATE_CURRENT_VIDEO" | jq '.title |= sub("^[0-9]+ "; "")')"

  echo "$current_recent" |
    jq "{
    \"entries\":[
      .entries[]
      | select(.id != \"$id\")
      ]
    }
  |.entries+=[$video_entry]" |
    jq "{\"entries\":.entries[-$CONFIG_NO_OF_RECENT:]}" >"$CLI_RECENT_FILE"
}

