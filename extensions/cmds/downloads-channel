#!/bin/sh
# shellcheck disable=SC3043,SC2034,SC1090

# ==============================================================================
# Preview Generators
# ==============================================================================
_preview_local() {
  while IFS= read -r line; do
    if [ "$CONFIG_ENABLE_PREVIEW" = "true" ] && [ "$line" != "$TXT_MENU_EXIT" ]; then
      local hash
      local script_path
      local img_path
      local thumbnailer_input_file
      local random_seek

      hash="$(_util_generate_hash "$line")"
      script_path="$CLI_LOCAL_PREVIEWS_SCRIPTS_DIR/$hash.sh"
      img_path="$CLI_LOCAL_PREVIEWS_IMGS_DIR/$hash.jpg"

      if [ -z "$1" ]; then
        thumbnailer_input_file="$(find "$CONFIG_DOWNLOAD_DIR/$line" -type f 2>/dev/null | awk 'BEGIN{srand()} rand() * NR < 1 {line = $0} END {print line}')"
      else
        thumbnailer_input_file="$(find "$1" -type f 2>/dev/null | awk 'BEGIN{srand()} rand() * NR < 1 {line = $0} END {print line}')"
      fi

      random_seek=$(od -An -N2 -i /dev/urandom | awk '{print ($1 % 100) + 1}')
      ffmpegthumbnailer -i "$thumbnailer_input_file" -o "$img_path" -t "$random_seek" -s 0 -m >/dev/null 2>&1

      if [ "$CONFIG_LAUNCHER" = "fzf" ]; then
        # FZF expects `{1}|{2}` where {1} is the script and {2} is the display name
        printf "%s|%s\n" "$script_path" "$line"
      elif [ "$CONFIG_LAUNCHER" = "rofi" ]; then
        printf "%s\0icon\x1f%s\n" "$line" "$img_path"
      else
        echo "$line"
        return
      fi

      if [ "$CONFIG_LAUNCHER" = "fzf" ]; then
        cat <<EOF >"$script_path"
. "$CLI_PREVIEW_SCRIPTS_DIR/fzf-preview.sh"
[ -s "$img_path" ] && fzf_preview "$img_path" 2>/dev/null 
EOF
      fi
    else
      # Pass through normally if previews are disabled or it's a menu action
      echo "$line"
    fi
  done
}

# ==============================================================================
# Main Loop Override
# ==============================================================================
_menu_main() {
  # Ensure standard fzf preview utilities are configured
  [ "$CONFIG_ENABLE_PREVIEW" = "true" ] && __preview_fzf_create_shared_script

  if ! _dep_ch fd; then
    ui_notify_warning "Error: 'fd' missing."
    return 1
  fi
  if [ ! -d "$CONFIG_DOWNLOAD_DIR" ]; then
    ui_notify_warning "Downloads directory not found: $CONFIG_DOWNLOAD_DIR"
    _util_byebye
  fi

  while true; do
    local type channel temp_playlist

    # 1. Select Type
    if [ "$CONFIG_ENABLE_PREVIEW" = "true" ] && [ "$CONFIG_LAUNCHER" = "fzf" ]; then
      type=$(printf "%s\n%s" "$(command ls "$CONFIG_DOWNLOAD_DIR" 2>/dev/null)" "$TXT_MENU_EXIT" | _preview_local_type | ui_launcher_with_preview "Select the type of file to play")
    else
      type=$(printf "%s\n%s" "$(command ls "$CONFIG_DOWNLOAD_DIR" 2>/dev/null)" "$TXT_MENU_EXIT" | ui_launcher "Select the type of file to play")
    fi

    case "$type" in
    "$TXT_MENU_EXIT" | "") _util_byebye ;;
    esac

    # 2. Select Channel/Playlist
    # We CD briefly just so `fd` operates correctly on relative structure
    local prev_dir="$PWD"
    cd "$CONFIG_DOWNLOAD_DIR/$type" || continue

    if [ "$CONFIG_ENABLE_PREVIEW" = "true" ] && [ "$CONFIG_LAUNCHER" = "fzf" ]; then
      channel=$(printf "%s\n%s" "$(fd --exact-depth 2 2>/dev/null | cut -d / -f 2 | sort | uniq)" "$TXT_MENU_BACK" | _preview_local_channel "$type" | ui_launcher_with_preview "Select the playlist to play")
    else
      channel=$(printf "%s\n%s" "$(fd --exact-depth 2 2>/dev/null | cut -d / -f 2 | sort | uniq)" "$TXT_MENU_BACK" | ui_launcher "Select the playlist to play")
    fi

    cd "$prev_dir" || continue

    case "$channel" in
    "$TXT_MENU_BACK" | "") continue ;;
    esac

    # 3. Build .m3u8 Playlist & Play
    # (Pure POSIX sh - Replaces the original bash `paths=()` array implementation)
    temp_playlist="$CLI_CACHE_DIR/local_playlist_$(_util_generate_hash "$channel").m3u8"
    echo "#EXTM3U" >"$temp_playlist"

    # Write all media absolute paths directly into the playlist
    cd "$CONFIG_DOWNLOAD_DIR/$type" || continue
    fd --absolute-path --exact-depth 2 "$channel" >>"$temp_playlist"
    cd "$prev_dir" || continue

    # Ensure playlist isn't empty before trying to launch media player
    if [ "$(wc -l <"$temp_playlist")" -gt 1 ]; then
      play "$temp_playlist"
    else
      ui_notify_warning "No media found in selected directory!"
    fi

    # 4. Loop continuation
    ui_confirm "Do you want to play another channel?" || _util_byebye
  done
}
