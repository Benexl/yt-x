#!/bin/sh

# Setup dedicated local cache directory
CLI_LOCAL_PREVIEWS_MIX_EXPLORER="$CLI_CACHE_DIR/local_previews_mix_creator"
![ -d "$CLI_LOCAL_PREVIEWS_MIX_EXPLORER" ] && mkdir -p "$CLI_LOCAL_PREVIEWS_MIX_EXPLORER"
CLI_MIXES_DIR="$CLI_CONFIG_DIR/mixes"

# ==============================================================================
# Preview Generators
# ==============================================================================
_preview_local_mix() {
  local mix_dir="$1"
  
  while IFS= read -r line; do
    if [ "$CONFIG_ENABLE_PREVIEW" = "true" ] &&[ "$CONFIG_LAUNCHER" = "fzf" ] && [ "$line" != "$TXT_MENU_BACK" ]; then
      local hash script_path mix_full_path
      hash="$(_util_generate_hash "$mix_dir/$line")"
      script_path="$CLI_PREVIEW_SCRIPTS_DIR/$hash.sh"
      mix_full_path="$mix_dir/$line"
      
      echo "$hash.sh|$line"
      
      if [ ! -s "$script_path" ]; then
        cat <<EOF >"$script_path"
. "$CLI_PREVIEW_SCRIPTS_DIR/fzf-preview.sh"

# Extract first valid media file from the playlist
first_media=\$(grep -v "^#" "$mix_full_path" | while read -r f; do if [ -f "\$f" ]; then echo "\$f"; break; fi; done)

if [ -n "\$first_media" ]; then
    dest_file="$CLI_LOCAL_PREVIEWS_MIX_EXPLORER/\$(_util_generate_hash "\$first_media").jpg"
    ! [ -s "\$dest_file" ] && ffmpegthumbnailer -i "\$first_media" -o "\$dest_file" -s 0 -m >/dev/null 2>&1
    [ -s "\$dest_file" ] && fzf_preview "\$dest_file" 2>/dev/null
fi

draw_divider
echo "${THEME_BOLD}Mix:${THEME_RESET} \$(basename "$line" .m3u8)"

if[ -n "\$first_media" ]; then
    echo "${THEME_FZF_PREVIEW_KEY}Previewing:${THEME_RESET} \$(basename "\$first_media")"
else
    echo "No previewable item found in mix."
fi

draw_divider
echo "${THEME_BOLD}--- First 5 Tracks ---${THEME_RESET}"
grep "^#EXTINF" "$mix_full_path" | head -n 5 | sed 's/#EXTINF:-1,//;s/^/• /'
EOF
      fi
    else
      echo "$line"
    fi
  done
}

# ==============================================================================
# Main Loop Override
# ==============================================================================
_menu_main() {
  # Ensure standard fzf preview utilities are configured
  [ "$CONFIG_ENABLE_PREVIEW" = "true" ] && __preview_fzf_create_shared_script

  if ! _dep_ch fd; then ui_notify_warning "Error: 'fd' missing."; return 1; fi
  if ! [ -d "$CLI_MIXES_DIR" ]; then ui_notify_warning "Mixes directory not found: $CLI_MIXES_DIR"; return 1; fi

  while true; do
    local mix_type mix_dir mix_file mix_action
    
    # 1. Select Mix Type
    mix_type=$(printf "audio\nvideo\n%s" "$TXT_MENU_EXIT" | ui_launcher "Explore which type of mixes?")
    
    case "$mix_type" in
      "$TXT_MENU_EXIT" | "") _util_byebye ;;
      audio|video) mix_dir="$CLI_MIXES_DIR/$mix_type" ;;
      *) continue ;;
    esac

    if ! [ -d "$mix_dir" ]; then
      ui_notify_warning "No '$mix_type' mixes directory found."
      continue
    fi

    while true; do
      local prev_dir="$PWD"
      cd "$mix_dir" || continue
      
      # 2. Select Mix File
      if [ "$CONFIG_ENABLE_PREVIEW" = "true" ] &&[ "$CONFIG_LAUNCHER" = "fzf" ]; then
        mix_file=$(printf "%s\n%s" "$(fd --type f --extension m3u8 2>/dev/null | sed 's|^\./||')" "$TXT_MENU_BACK" | _preview_local_mix "$mix_dir" | ui_launcher_with_preview "Select '$mix_type' mix")
      else
        mix_file=$(printf "%s\n%s" "$(fd --type f --extension m3u8 2>/dev/null | sed 's|^\./||')" "$TXT_MENU_BACK" | ui_launcher "Select '$mix_type' mix")
      fi

      cd "$prev_dir" || continue

      case "$mix_file" in
        "$TXT_MENU_BACK" | "") break ;; # Break inner loop, go back to type selection
      esac

      local selected_m3u8_path="$mix_dir/$mix_file"
      local mix_name="$(basename "$mix_file" .m3u8)"

      if ![ -f "$selected_m3u8_path" ]; then
        ui_notify_warning "Error: Could not retrieve selected mix path."
        continue
      fi

      # 3. Action Menu
      mix_action=$(printf "Play Mix\nDelete Mix\n%s" "$TXT_MENU_BACK" | ui_launcher "Action for '$mix_name'")

      case "$mix_action" in
        "Play Mix")
          ui_notify "Playing mix: $mix_name"
          # Utilizing yt-x's native media wrapper modes!
          if [ "$mix_type" = "audio" ]; then
            play "$selected_m3u8_path" "listen"
          else
            play "$selected_m3u8_path" "watch"
          fi
          ;;
          
        "Delete Mix")
          if ui_confirm "Really delete mix '$mix_name'?"; then
            if rm "$selected_m3u8_path"; then
              ui_notify "Mix '$mix_name' deleted."
              break # Break to refresh the list
            else
              ui_notify_error "Failed to delete mix '$mix_name'."
            fi
          else
             ui_notify "Deletion cancelled."
          fi
          ;;
          
        "$TXT_MENU_BACK" | "")
          continue
          ;;
      esac
    done
  done
}
